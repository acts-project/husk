# Pinned inputs for images/build.sh — the single source of truth for what goes
# into the husk golden images. Bump deliberately; CI records these as provenance
# annotations on the published artifact. See image-pipeline.md.

# GitHub Actions runner. Keep in sync with [runner] version in huskd config.
RUNNER_VERSION=2.334.0

# Base cloud image, pinned to a dated AlmaLinux 10 GenericCloud build for
# reproducibility (the -latest URL drifts). build.sh verifies the SHA256.
# Bump both together from https://repo.almalinux.org/almalinux/10/cloud/x86_64/images/CHECKSUM
BASE_IMAGE_URL=https://repo.almalinux.org/almalinux/10/cloud/x86_64/images/AlmaLinux-10-GenericCloud-10.2-20260526.0.x86_64.qcow2
BASE_IMAGE_SHA256=47f2218668dd4776be140dd92fa3bea700be1766e2c7d88bdfd6a4b50f477b4d

# node_exporter — the in-guest per-VM metrics source (CPU/mem/net and, the reason
# it must live in the guest rather than on the hypervisor, filesystem fill).
# Baked into BOTH variants but never enabled for boot: cloud-init starts it each
# cycle, and only for pools that set `scrape_cidr`. See observability.md.
NODE_EXPORTER_VERSION=1.12.0
NODE_EXPORTER_SHA256=b206d98e98a431f2687d4c217abb4b15c46a6b272896113ce9a1585cf1a75d1f

# Final root disk size (the base image is grown to this up front; can't go BELOW
# the base's native 10 GiB without shrinking the in-image filesystem). Per-variant
# because the targets differ: the base golden also boots on OpenStack, where it
# must fit the flavor root disk (CERN m2.small = 10 GiB); the gpu golden runs on
# libvirt hosts that need room for the NVIDIA driver + CUDA + CI scratch.
BASE_DISK_SIZE=10G
GPU_DISK_SIZE=30G
