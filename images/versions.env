# Pinned inputs for images/build.sh — the single source of truth for what goes
# into the husk golden images. Bump deliberately; CI records these as provenance
# annotations on the published artifact. See image-pipeline.md.

# GitHub Actions runner. Keep in sync with [runner] version in huskd config.
RUNNER_VERSION=2.334.0

# Base cloud image. TODO(repro): pin to a dated AlmaLinux 10 GenericCloud build
# and fill BASE_IMAGE_SHA256 — the -latest URL drifts, defeating reproducibility.
BASE_IMAGE_URL=https://repo.almalinux.org/almalinux/10/cloud/x86_64/images/AlmaLinux-10-GenericCloud-latest.x86_64.qcow2
BASE_IMAGE_SHA256=

# Final root disk size (the COW backing file is resized up front).
DISK_SIZE=30G
