.env
*.pyc
.venv/
__pycache__/
*.egg-info/
build/
dist/
.pytest_cache/
husk-test
config.toml

# Local libvirt configs (name the repo; keep local). The committed example is
# config.libvirt.example.toml, which the negation below keeps tracked.
config.libvirt.*.toml
!config.libvirt.example.toml

# Local OpenStack variants (e.g. the OCI/prebaked soak config). The committed
# template stays config.example.toml.
config.openstack.*.toml

# Local multi-pool daemon config (OpenStack + libvirt CPU + libvirt GPU at once).
config.multi.toml

# ── credentials ─────────────────────────────────────────────────────────────
# Everything huskd needs to authenticate, kept in the working tree but never
# committed. `just k8s-secrets` reads from here and loads them into the cluster.
#   secrets/private-key.pem   GitHub App private key (App settings -> Private keys)
#   secrets/clouds.yaml       openstacksdk profile with the CERN app credential
secrets/

# Belt and braces: no PEM anywhere in the tree, whatever it's called. A GitHub App
# key grants installation tokens for every org/repo the App is on, so a stray
# `git add -A` must never be able to pick one up.
*.pem
*.key

# The k8s overlays' real configs (k8s/overlays/*/config.toml) are already covered
# by the bare `config.toml` rule above. The committed templates are the
# config.example.toml next to each — see k8s/README.md.

# macOS Finder metadata — was tracked once; never useful in a diff.
.DS_Store
